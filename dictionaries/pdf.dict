# ============================================
# Interesting delimiters and structures
# ============================================
pdf_dict_open="<<"
pdf_dict_close=">>"
pdf_array_open="["
pdf_array_close="]"
pdf_name="/"
pdf_string_open="("
pdf_string_close=")"
pdf_hex_open="<"
pdf_hex_close=">"
pdf_comment="%"

# ============================================
# Common dimension/size values
# ============================================
pdf_letter_box="[0 0 612 792]"
pdf_a4_box="[0 0 595 842]"
pdf_zero_box="[0 0 0 0]"
pdf_huge_box="[0 0 99999 99999]"
pdf_neg_box="[-100 -100 100 100]"
