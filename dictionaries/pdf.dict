#
# pdf.dict - libFuzzer dictionary for CoreGraphics PDF fuzzing
# Covers: PDF structure, operators, filters, fonts, images, XObjects
# Target: CoreGraphics PDF renderer (zero-click via iMessage/Mail/Preview)
#

# ============================================
# PDF header and version
# ============================================
pdf_magic="%PDF"
pdf_10="%PDF-1.0"
pdf_11="%PDF-1.1"
pdf_12="%PDF-1.2"
pdf_13="%PDF-1.3"
pdf_14="%PDF-1.4"
pdf_15="%PDF-1.5"
pdf_16="%PDF-1.6"
pdf_17="%PDF-1.7"
pdf_20="%PDF-2.0"
# Binary comment (signals binary content)
pdf_bincomment="%\xe2\xe3\xcf\xd3"

# ============================================
# PDF structural keywords
# ============================================
pdf_obj="obj"
pdf_endobj="endobj"
pdf_stream="stream"
pdf_endstream="endstream"
pdf_xref="xref"
pdf_trailer="trailer"
pdf_startxref="startxref"
pdf_eof="%%EOF"
pdf_null="null"
pdf_true="true"
pdf_false="false"
pdf_r=" R"
pdf_obj_ref=" 0 R"
pdf_obj_def=" 0 obj"
pdf_r_ref="0 R"

# ============================================
# Cross-reference streams (PDF 1.5+)
# ============================================
pdf_xrefstm="/Type /XRef"

# ============================================
# Document structure
# ============================================
pdf_type="/Type"
pdf_catalog="/Catalog"
pdf_pages="/Pages"
pdf_page="/Page"
pdf_type_catalog="/Type /Catalog"
pdf_type_pages="/Type /Pages"
pdf_type_page="/Type /Page"
pdf_count="/Count"
pdf_kids="/Kids"
pdf_parent="/Parent"
pdf_mediabox="/MediaBox"
pdf_cropbox="/CropBox"
pdf_bleedbox="/BleedBox"
pdf_trimbox="/TrimBox"
pdf_artbox="/ArtBox"
pdf_rotate="/Rotate"
pdf_resources="/Resources"
pdf_contents="/Contents"

# ============================================
# Fonts
# ============================================
pdf_font="/Font"
pdf_type_font="/Type /Font"
pdf_subtype="/Subtype"
pdf_type1="/Subtype /Type1"
pdf_truetype="/Subtype /TrueType"
pdf_type0="/Subtype /Type0"
pdf_type3="/Subtype /Type3"
pdf_cidfonttype0="/Subtype /CIDFontType0"
pdf_cidfonttype2="/Subtype /CIDFontType2"
